#!/bin/bash
set -euo pipefail
LOG=/var/log/openclaw-bootstrap.log
exec > >(tee -a "$LOG") 2>&1

echo "=== OpenClaw bootstrap started $(date) ==="
sleep 10

# Install Node.js
curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | \
  gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg
echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" \
  > /etc/apt/sources.list.d/nodesource.list
apt-get update -qq && apt-get install -y nodejs

# Install OpenClaw
sudo -u snorp bash -c "curl -fsSL https://openclaw.ai/install.sh | bash -s -- --no-onboard"

echo "=== Bootstrap complete. Run make configure-openclaw from your workstation. ==="